{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/gitlode/gitlode/schemas/config-v1.schema.json",
  "title": "gitlode configuration v1",
  "description": "Schema for gitlode --config files (version 1).",
  "type": "object",
  "additionalProperties": false,
  "required": ["version"],
  "properties": {
    "version": {
      "const": 1
    },
    "extraction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "range": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "sinceRef": {
              "type": "string",
              "minLength": 1
            },
            "sinceDate": {
              "type": "string",
              "minLength": 1,
              "format": "date-time"
            }
          },
          "oneOf": [{ "required": ["sinceRef"] }, { "required": ["sinceDate"] }]
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "directory": {
          "type": "string",
          "minLength": 1
        },
        "prefix": {
          "type": "string",
          "minLength": 1
        },
        "rotation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "lines": {
              "type": "integer",
              "minimum": 1
            },
            "size": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "profile": {
          "type": "boolean"
        }
      }
    },
    "extensions": {
      "type": "object",
      "patternProperties": {
        "^[a-z0-9-]+$": {
          "type": "object",
          "additionalProperties": false,
          "required": ["entrypoint"],
          "properties": {
            "entrypoint": {
              "type": "string",
              "minLength": 1
            },
            "config": {},
            "failurePolicy": {
              "enum": ["skip-fact", "fatal"],
              "default": "skip-fact"
            }
          }
        }
      },
      "additionalProperties": false,
      "minProperties": 1
    }
  }
}
