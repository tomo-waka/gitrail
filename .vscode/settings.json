{
  // Terminal
  "terminal.integrated.env.windows": {
    "LANG": "en_US.UTF-8"
  },

  // AI / chat
  "chat.disableAIFeatures": false,
  "github.copilot.enable": {
    "*": true
  },

  // Dictonary
  "cSpell.words": [
    "citty",
    "gitrail",
    "libgit",
    "nodegit",
    "oids",
    "oxfmt",
    "oxlint",
    "touchpoint",
    "Touchpoints"
  ],

  // Formatter
  "editor.defaultFormatter": "oxc.oxc-vscode"
}
