{
  "name": "gitrail",
  "version": "0.2.0",
  "description": "Extract Git commit history to JSON Lines (JSONL) for data warehouse ingestion",
  "keywords": [
    "cli",
    "data-warehouse",
    "etl",
    "git",
    "jsonl"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tomo-waka/gitrail.git"
  },
  "bin": {
    "gitrail": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "format": "node -e \"console.error('Error: Please run format:check or format:write instead.'); process.exit(1)\"",
    "format:check": "oxfmt --check",
    "format:write": "oxfmt",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "citty": "^0.2.2",
    "isomorphic-git": "^1.27.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "memfs": "^4.57.1",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.60.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
